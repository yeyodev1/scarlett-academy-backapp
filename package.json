{
  "name": "scarlett-academy-backapp",
  "version": "1.0.0",
  "description": "Backend de Scarlett Cordova para el ebook Quema Grasa, Construye Musculo",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "compile": "tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "delete:user": "ts-node src/scripts/delete-user.ts",
    "delete:dreyes": "ts-node src/scripts/delete-user.ts dreyes@bakano.ec",
    "fix:access": "ts-node src/scripts/fix-access.ts",
    "start": "node dist/index.js",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,json,css,scss,md}'"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.2.0",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
